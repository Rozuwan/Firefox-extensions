{
  "manifest_version": 3,
  "name": "YouTube Focus Mode",
  "version": "1.2.0",
  "description": "Stay focused on YouTube — hide Shorts, recommendations, comments, and the homepage feed.",
  "author": "YouTube Focus Mode",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "YouTube Focus Mode"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ytfocus@roxu.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}